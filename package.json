{
  "name": "bad-apple-video-gallery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "classify:data": "node scripts/classify-videos.mjs",
    "download:but-videos": "node scripts/download-but-videos.mjs",
    "estimate:sizes": "node scripts/estimate-download-sizes.mjs",
    "prepare:data": "node scripts/build-data.mjs",
    "refresh:data": "npm run classify:data && npm run prepare:data",
    "dev": "npm run prepare:data && vite --host 0.0.0.0",
    "build": "npm run prepare:data && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "description": "> A curated list of Bad Apple!! recreations, covers, ports, demos, and \"played on everything\" experiments.",
  "main": "index.js",
  "dependencies": {
    "esbuild": "^0.27.7",
    "fdir": "^6.5.0",
    "fsevents": "^2.3.3",
    "nanoid": "^3.3.12",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "rollup": "^4.60.4",
    "source-map-js": "^1.2.1",
    "tinyglobby": "^0.2.16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickLennonLiu/Bad-Apple-Buts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/NickLennonLiu/Bad-Apple-Buts/issues"
  },
  "homepage": "https://github.com/NickLennonLiu/Bad-Apple-Buts#readme"
}
